    "STRUCTURE_SCHEMA = (\n",
    "    '[{\"title\": str, \"content\": str, '\n",
    "    '\"section_type\": \"intro|theory|equation|example|summary|exercise\", '\n",
    "    '\"page_start\": int, \"page_end\": int, \"key_concepts\": [str]}]'\n",
    ")\n",
    "\n",
    "STRUCTURE_PROMPT = \"\"\"Analyze this physics textbook content (pages {pages}) and return a JSON array of logical sections.\n",
    "Each section must cover one coherent topic.\n",
    "\n",
    "Content:\n",
    "{text}\n",
    "\n",
    "Return ONLY valid JSON matching this schema (no markdown fences, no commentary):\n",
    "{schema}\"\"\"\n",
    "\n",
    "\n",
    "def _safe_parse_json(raw: str) -> Optional[List[Dict]]:\n",
    "    \"\"\"Strip code fences and parse JSON. Returns None on failure.\"\"\"\n",
    "    raw = re.sub(r'^```(?:json)?\\s*', '', raw.strip())\n",
    "    raw = re.sub(r'\\s*```$', '', raw)\n",
    "    try:\n",
    "        data = json.loads(raw)\n",
    "        if isinstance(data, list) and len(data) > 0:\n",
    "            return data\n",
    "    except json.JSONDecodeError:\n",
    "        # Try to extract first JSON array with regex as last resort\n",
    "        m = re.search(r'\\[.*\\]', raw, re.DOTALL)\n",
    "        if m:\n",
    "            try:\n",
    "                data = json.loads(m.group())\n",
    "                if isinstance(data, list):\n",
    "                    return data\n",
    "            except Exception:\n",
    "                pass\n",
    "    return None\n",
    "\n",
    "\n",
    "# ─── Structuring: Gemini ──────────────────────────────────────────────────────\n",
    "def structure_gemini(text: str, pages: List[int]) -> Optional[List[Dict]]:\n",
    "    if not GEMINI_API_KEY:\n",
    "        return None\n",
    "    try:\n",
    "        model = genai.GenerativeModel(\n",
    "            GEMINI_MODEL,\n",
    "            generation_config=genai.GenerationConfig(temperature=0.1, max_output_tokens=4096)\n",
    "        )\n",
    "        prompt = STRUCTURE_PROMPT.format(\n",
    "            pages=pages, text=text[:9000], schema=STRUCTURE_SCHEMA\n",
    "        )\n",
    "        resp = model.generate_content(prompt)\n",
    "        return _safe_parse_json(resp.text)\n",
    "    except Exception as e:\n",
    "        print(f\"    ⚠️  Gemini structuring error: {e}\")\n",
    "        return None\n",
    "\n",
    "\n",
    "# ─── Structuring: OpenRouter (Gemma 3) ────────────────────────────────────────\n",
    "def _openrouter_chat(model: str, user_msg: str, max_tokens: int = 4096) -> Optional[str]:\n",
    "    if not OPENROUTER_API_KEY:\n",
    "        return None\n",
    "    try:\n",
    "        resp = requests.post(\n",
    "            \"https://openrouter.ai/api/v1/chat/completions\",\n",
    "            headers={\n",
    "                \"Authorization\": f\"Bearer {OPENROUTER_API_KEY}\",\n",
    "                \"Content-Type\": \"application/json\",\n",
    "                \"HTTP-Referer\": \"https://saral-labs-bootcamp\",\n",
    "            },\n",
    "            json={\"model\": model,\n",
    "                  \"messages\": [{\"role\": \"user\", \"content\": user_msg}],\n",
    "                  \"max_tokens\": max_tokens},\n",
    "            timeout=120\n",
    "        )\n",
    "        resp.raise_for_status()\n",
    "        return resp.json()[\"choices\"][0][\"message\"][\"content\"]\n",
    "    except Exception as e:\n",
    "        print(f\"    ⚠️  OpenRouter ({model}) error: {e}\")\n",
    "        return None\n",
    "\n",
    "\n",
    "def structure_gemma(text: str, pages: List[int]) -> Optional[List[Dict]]:\n",
    "    raw = _openrouter_chat(\n",
    "        GEMMA_MODEL,\n",
    "        STRUCTURE_PROMPT.format(pages=pages, text=text[:7000], schema=STRUCTURE_SCHEMA)\n",
    "    )\n",
    "    return _safe_parse_json(raw) if raw else None\n",
    "\n",
    "\n",
    "# ─── Structuring: xAI Grok ────────────────────────────────────────────────────\n",
    "def structure_grok(text: str, pages: List[int]) -> Optional[List[Dict]]:\n",
    "    if not XAI_API_KEY:\n",
    "        return None\n",
    "    try:\n",
    "        resp = requests.post(\n",
    "            \"https://api.x.ai/v1/chat/completions\",\n",
    "            headers={\"Authorization\": f\"Bearer {XAI_API_KEY}\",\n",
    "                     \"Content-Type\": \"application/json\"},\n",
    "            json={\n",
    "                \"model\": GROK_MODEL,\n",
    "                \"messages\": [\n",
    "                    {\"role\": \"system\",\n",
    "                     \"content\": \"You are a document structuring expert. Output only valid JSON.\"},\n",
    "                    {\"role\": \"user\",\n",
    "                     \"content\": STRUCTURE_PROMPT.format(\n",
    "                         pages=pages, text=text[:7000], schema=STRUCTURE_SCHEMA)}\n",
    "                ],\n",
    "                \"max_tokens\": 4096\n",
    "            },\n",
    "            timeout=120\n",
    "        )\n",
    "        resp.raise_for_status()\n",
    "        raw = resp.json()[\"choices\"][0][\"message\"][\"content\"]\n",
    "        return _safe_parse_json(raw)\n",
    "    except Exception as e:\n",
    "        print(f\"    ⚠️  xAI Grok structuring error: {e}\")\n",
    "        return None\n",
    "\n",
    "\n",
    "STRUCTURING_METHODS = [\n",
    "    (\"Gemini 2.0 Flash\",       structure_gemini),\n",
    "    (\"Gemma 3 27B (OpenRouter)\", structure_gemma),\n",
    "    (\"Grok 3 Mini (xAI)\",      structure_grok),\n",
    "]\n",
    "\n",
    "\n",
    "def structure_chunk(text: str, pages: List[int]) -> List[Dict]:\n",
    "    \"\"\"Structure a text chunk with tertiary LLM fallback.\"\"\"\n",
    "    for name, fn in STRUCTURING_METHODS:\n",
    "        print(f\"    🧠 Trying {name}...\")\n",
    "        result = fn(text, pages)\n",
    "        if result:\n",
    "            print(f\"    ✅ {len(result)} section(s) from {name}\")\n",
    "            return result\n",
    "        time.sleep(1)\n",
    "\n",
    "    # Rule-based fallback: treat whole chunk as one section\n",
    "    print(\"    ⚙️  Rule-based fallback applied\")\n",
    "    return [{\n",
    "        \"title\": f\"Pages {pages[0]}–{pages[-1]}\",\n",
    "        \"content\": text,\n",
    "        \"section_type\": \"theory\",\n",
    "        \"page_start\": pages[0],\n",
    "        \"page_end\": pages[-1],\n",
    "        \"key_concepts\": []\n",
    "    }]\n",
    "\n",
    "\n",
    "print(\"✅ Document structuring functions defined\")"
   ]
