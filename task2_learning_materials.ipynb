    "## 🔍 Step 3 — OCR Pipeline (Tertiary Fallback)\n",
    "\n",
    "| Priority | Engine | When used |\n",
    "|----------|--------|-----------|\n",
    "| 1st | **Gemini 2.0 Flash Vision** | Always tried first (best quality) |\n",
    "| 2nd | **Qwen 2.5-VL 72B** via OpenRouter | If Gemini fails / unavailable |\n",
    "| 3rd | **Tesseract** (local) | Final safety net — no API needed |"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "outputs": [],
   "execution_count": null,
   "source": [
    "# ─── Quality Check ────────────────────────────────────────────────────────────\n",
    "def is_good_ocr(text: str, min_chars: int = 80) -> bool:\n",
    "    \"\"\"Heuristic: reject if too short, too many non-ASCII runs, or mostly garbage.\"\"\"\n",
    "    if not text or len(text) < min_chars:\n",
    "        return False\n",
    "    non_ascii_ratio = sum(1 for c in text if ord(c) > 127) / max(len(text), 1)\n",
    "    if non_ascii_ratio > 0.25:\n",
    "        return False\n",
    "    word_count = len(text.split())\n",
    "    return word_count >= 15\n",
    "\n",
    "\n",
    "# ─── OCR Method 1: Gemini Vision ──────────────────────────────────────────────\n",
    "def ocr_gemini(img: Image.Image, page_num: int) -> Optional[str]:\n",
    "    \"\"\"Extract text with Gemini 2.0 Flash (vision).\"\"\"\n",
    "    try:\n",
    "        model = genai.GenerativeModel(\n",
    "            GEMINI_MODEL,\n",
    "            generation_config=genai.GenerationConfig(temperature=0.0, max_output_tokens=4096)\n",
    "        )\n",
    "        prompt = (\n",
    "            f\"You are a precise OCR engine. Extract ALL text from page {page_num} exactly as it appears.\\n\"\n",
    "            \"Rules:\\n\"\n",
    "            \"• Preserve section headings and their hierarchy\\n\"\n",
    "            \"• Write mathematical equations in LaTeX: $...$ inline, $$...$$ display\\n\"\n",
    "            \"• Include figure captions and table data verbatim\\n\"\n",
    "            \"• Mark page number found in image as [PAGE: n]\\n\"\n",
    "            \"• Output ONLY extracted text — no commentary\\n\"\n",
    "        )\n",
    "        response = model.generate_content([prompt, img])\n",
    "        text = response.text.strip()\n",
    "        return text if is_good_ocr(text) else None\n",
    "    except Exception as e:\n",
    "        print(f\"    ⚠️  Gemini OCR error (page {page_num}): {type(e).__name__}: {e}\")\n",
    "        return None\n",
    "\n",
    "\n",
    "# ─── OCR Method 2: Qwen VL via OpenRouter ─────────────────────────────────────\n",
    "def ocr_qwen(img: Image.Image, page_num: int) -> Optional[str]:\n",
    "    \"\"\"Extract text with Qwen2.5-VL 72B via OpenRouter.\"\"\"\n",
    "    if not OPENROUTER_API_KEY:\n",
    "        return None\n",
    "    try:\n",
    "        b64 = image_to_base64(img)\n",
    "        payload = {\n",
    "            \"model\": QWEN_VL_MODEL,\n",
    "            \"messages\": [{\n",
    "                \"role\": \"user\",\n",
    "                \"content\": [\n",
    "                    {\"type\": \"image_url\",\n",
    "                     \"image_url\": {\"url\": f\"data:image/png;base64,{b64}\"}},\n",
    "                    {\"type\": \"text\",\n",
    "                     \"text\": (\n",
    "                         f\"OCR page {page_num}. Extract ALL text preserving structure. \"\n",
    "                         \"Use LaTeX for equations ($...$ inline, $$...$$ display). \"\n",
    "                         \"Include headings, captions, tables. Output only extracted text.\"\n",
    "                     )}\n",
    "                ]\n",
    "            }],\n",
    "            \"max_tokens\": 4096\n",
    "        }\n",
    "        resp = requests.post(\n",
    "            \"https://openrouter.ai/api/v1/chat/completions\",\n",
    "            headers={\n",
    "                \"Authorization\": f\"Bearer {OPENROUTER_API_KEY}\",\n",
    "                \"Content-Type\": \"application/json\",\n",
    "                \"HTTP-Referer\": \"https://saral-labs-bootcamp\",\n",
    "                \"X-Title\": \"EMW OCR Pipeline\"\n",
    "            },\n",
    "            json=payload, timeout=90\n",
    "        )\n",
    "        resp.raise_for_status()\n",
    "        text = resp.json()[\"choices\"][0][\"message\"][\"content\"].strip()\n",
    "        return text if is_good_ocr(text) else None\n",
    "    except Exception as e:\n",
    "        print(f\"    ⚠️  Qwen OCR error (page {page_num}): {type(e).__name__}: {e}\")\n",
    "        return None\n",
    "\n",
    "\n",
    "# ─── OCR Method 3: Tesseract (local fallback) ─────────────────────────────────\n",
    "def ocr_tesseract(img: Image.Image, page_num: int) -> Optional[str]:\n",
    "    \"\"\"Extract text with Tesseract as the final fallback.\"\"\"\n",
    "    try:\n",
    "        # Grayscale + slight upscale improves Tesseract accuracy\n",
    "        gray = img.convert(\"L\")\n",
    "        w, h = gray.size\n",
    "        if w < 1600:\n",
    "            gray = gray.resize((w * 2, h * 2), Image.LANCZOS)\n",
    "        text = pytesseract.image_to_string(\n",
    "            gray,\n",
    "            config=\"--oem 3 --psm 6 -c preserve_interword_spaces=1\"\n",
    "        ).strip()\n",
    "        return text if is_good_ocr(text) else None\n",
    "    except Exception as e:\n",
    "        print(f\"    ⚠️  Tesseract error (page {page_num}): {type(e).__name__}: {e}\")\n",
    "        return None\n",
    "\n",
    "\n",
    "# ─── Master OCR with Fallback ─────────────────────────────────────────────────\n",
    "OCR_METHODS = [\n",
    "    (\"Gemini 2.0 Flash\",      ocr_gemini),\n",
    "    (\"Qwen 2.5-VL (OpenRouter)\", ocr_qwen),\n",
    "    (\"Tesseract (local)\",     ocr_tesseract),\n",
    "]\n",
    "\n",
    "def ocr_page(img: Image.Image, page_num: int) -> Dict[str, Any]:\n",
    "    \"\"\"Run OCR with tertiary fallback. Returns dict with text, method, quality.\"\"\"\n",
    "    enhanced = enhance_for_ocr(img)\n",
    "    for name, fn in OCR_METHODS:\n",
    "        needs_key = \"Gemini\" in name and not GEMINI_API_KEY\n",
    "        needs_or  = \"OpenRouter\" in name and not OPENROUTER_API_KEY\n",
    "        if needs_key or needs_or:\n",
    "            print(f\"    ⏭️  Skipping {name} (no key)\")\n",
    "            continue\n",
    "        result = fn(enhanced, page_num)\n",
    "        if result:\n",
    "            return {\"page\": page_num, \"text\": result,\n",
    "                    \"method\": name, \"chars\": len(result)}\n",
    "        time.sleep(0.8)   # gentle rate-limit between retries\n",
    "\n",
    "    print(f\"    ❌ All OCR methods failed for page {page_num}\")\n",
    "    return {\"page\": page_num, \"text\": \"\", \"method\": \"failed\", \"chars\": 0}\n",
    "\n",
    "print(\"✅ OCR functions defined\")"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "outputs": [],
   "execution_count": null,
   "source": [
    "# ─── Run OCR Pipeline (with caching) ─────────────────────────────────────────\n",
    "CACHE_FILE = os.path.join(CACHE_DIR, \"ocr_raw.json\")\n",
    "\n",
    "def run_ocr_pipeline(images: List[Image.Image], force_rerun: bool = False) -> List[Dict]:\n",
    "    \"\"\"Run OCR over all pages with progress tracking and caching.\"\"\"\n",
    "    if not force_rerun and os.path.exists(CACHE_FILE):\n",
    "        with open(CACHE_FILE) as f:\n",
    "            cached = json.load(f)\n",
    "        if len(cached) == len(images):\n",
    "            print(f\"⚡ Loaded {len(cached)} pages from cache ({CACHE_FILE})\")\n",
    "            return cached\n",
    "\n",
    "    results = []\n",
    "    method_counts: Dict[str, int] = {}\n",
    "\n",
    "    for i, img in enumerate(tqdm(images, desc=\"OCR Progress\", unit=\"page\")):\n",
    "        page_num = i + 1\n",
    "        print(f\"\\n📃 Page {page_num}/{len(images)}\")\n",
    "        result = ocr_page(img, page_num)\n",
    "        results.append(result)\n",
    "        method_counts[result[\"method\"]] = method_counts.get(result[\"method\"], 0) + 1\n",
    "\n",
    "        # Save checkpoint after each page so progress isn't lost on crash\n",
    "        with open(CACHE_FILE, \"w\") as f:\n",
    "            json.dump(results, f, ensure_ascii=False, indent=2)\n",
    "\n",
    "        time.sleep(1.2)  # polite rate-limiting\n",
    "\n",
    "    total_chars = sum(r[\"chars\"] for r in results)\n",
    "    print(f\"\\n{'='*55}\")\n",
    "    print(f\"✅ OCR complete — {len(results)} pages, {total_chars:,} characters\")\n",
    "    print(\"   Method breakdown:\")\n",
    "    for m, c in method_counts.items():\n",
    "        print(f\"     {m}: {c} page(s)\")\n",
    "    return results\n",
    "\n",
    "\n",
    "OCR_RESULTS = run_ocr_pipeline(PDF_IMAGES)\n",
    "print(f\"\\n📊 Sample (page 1, first 300 chars):\\n{OCR_RESULTS[0]['text'][:300]}\")"
   ]
  },
