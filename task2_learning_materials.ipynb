    "def _call_gemini_gen(system: str, user: str) -> Optional[str]:\n",
    "    if not GEMINI_API_KEY:\n",
    "        return None\n",
    "    try:\n",
    "        model = genai.GenerativeModel(\n",
    "            GEMINI_MODEL,\n",
    "            system_instruction=system,\n",
    "            generation_config=genai.GenerationConfig(\n",
    "                temperature=0.65, max_output_tokens=8192\n",
    "            )\n",
    "        )\n",
    "        resp = model.generate_content(user)\n",
    "        text = resp.text.strip()\n",
    "        return text if len(text) > 300 else None\n",
    "    except Exception as e:\n",
    "        print(f\"    ⚠️  Gemini gen error: {e}\")\n",
    "        return None\n",
    "\n",
    "\n",
    "def _call_openrouter_gen(system: str, user: str, model: str) -> Optional[str]:\n",
    "    raw = _openrouter_chat(\n",
    "        model,\n",
    "        f\"{system}\\n\\n{user}\",\n",
    "        max_tokens=6000\n",
    "    )\n",
    "    return raw if raw and len(raw) > 300 else None\n",
    "\n",
    "\n",
    "def _call_xai_gen(system: str, user: str) -> Optional[str]:\n",
    "    if not XAI_API_KEY:\n",
    "        return None\n",
    "    try:\n",
    "        resp = requests.post(\n",
    "            \"https://api.x.ai/v1/chat/completions\",\n",
    "            headers={\"Authorization\": f\"Bearer {XAI_API_KEY}\",\n",
    "                     \"Content-Type\": \"application/json\"},\n",
    "            json={\n",
    "                \"model\": GROK_MODEL,\n",
    "                \"messages\": [{\"role\": \"system\", \"content\": system},\n",
    "                              {\"role\": \"user\",   \"content\": user}],\n",
    "                \"max_tokens\": 6000\n",
    "            },\n",
    "            timeout=120\n",
    "        )\n",
    "        resp.raise_for_status()\n",
    "        text = resp.json()[\"choices\"][0][\"message\"][\"content\"]\n",
    "        return text if len(text) > 300 else None\n",
    "    except Exception as e:\n",
    "        print(f\"    ⚠️  xAI Grok gen error: {e}\")\n",
    "        return None\n",
    "\n",
    "\n",
    "GENERATION_METHODS = [\n",
    "    (\"Gemini 2.0 Flash\",         _call_gemini_gen),\n",
    "    (\"Gemma 3 27B (OpenRouter)\",  lambda s, u: _call_openrouter_gen(s, u, GEMMA_MODEL)),\n",
    "    (\"Grok 3 Mini (xAI)\",        _call_xai_gen),\n",
    "]\n",
    "\n",
    "\n",
    "def generate_material(content: str, level: str) -> str:\n",
    "    \"\"\"Generate Easy or Difficult learning material with tertiary fallback.\"\"\"\n",
    "    assert level in (\"easy\", \"difficult\")\n",
    "    system   = EASY_SYSTEM   if level == \"easy\" else DIFFICULT_SYSTEM\n",
    "    user_tpl = EASY_USER     if level == \"easy\" else DIFFICULT_USER\n",
    "    user     = user_tpl.format(content=content[:14000])\n",
    "\n",
    "    label = \"📗 Easy\" if level == \"easy\" else \"📕 Difficult\"\n",
    "    print(f\"\\n{label} material generation:\")\n",
    "\n",
    "    for name, fn in GENERATION_METHODS:\n",
    "        needs_or = \"OpenRouter\" in name and not OPENROUTER_API_KEY\n",
    "        if needs_or:\n",
    "            continue\n",
    "        print(f\"  🤖 Trying {name}...\")\n",
    "        result = fn(system, user)\n",
    "        if result:\n",
    "            print(f\"  ✅ {name} → {len(result):,} chars\")\n",
    "            return result\n",
    "        time.sleep(2)\n",
    "\n",
    "    return f\"# {label} Material\\n\\n*Error: all generation methods failed. Check API keys.*\"\n",
    "\n",
    "\n",
    "# Generate both levels\n",
    "EASY_MATERIAL      = generate_material(REFINED_TEXT, \"easy\")\n",
    "DIFFICULT_MATERIAL = generate_material(REFINED_TEXT, \"difficult\")\n",
    "\n",
    "# Save Markdown files\n",
    "with open(os.path.join(OUTPUT_DIR, \"easy_learning_material.md\"), \"w\") as f:\n",
    "    f.write(EASY_MATERIAL)\n",
    "with open(os.path.join(OUTPUT_DIR, \"difficult_learning_material.md\"), \"w\") as f:\n",
    "    f.write(DIFFICULT_MATERIAL)\n",
    "\n",
    "print(f\"\\n✅ Saved easy ({len(EASY_MATERIAL):,} chars) and difficult ({len(DIFFICULT_MATERIAL):,} chars) materials\")"
   ]
  },
