   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 🧹 Step 4 — Text Normalization"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "outputs": [],
   "execution_count": null,
   "source": [
    "def normalize_page(text: str) -> str:\n",
    "    \"\"\"Clean a single page's OCR text.\"\"\"\n",
    "    if not text:\n",
    "        return \"\"\n",
    "\n",
    "    # Remove common PDF artefacts\n",
    "    text = re.sub(r'Reprint\\s+\\d{4}-\\d{2,4}', '', text)\n",
    "    text = re.sub(r'©\\s*NCERT\\b[^\\n]*', '', text)\n",
    "    text = re.sub(r'not\\s+to\\s+be\\s+republished[^\\n]*', '', text, flags=re.IGNORECASE)\n",
    "\n",
    "    # Dehyphenate line-break splits (e.g. \"elec-\\ntric\" → \"electric\")\n",
    "    text = re.sub(r'(?<=[a-z])-\\n(?=[a-z])', '', text)\n",
    "\n",
    "    # Merge hard-wrapped lines that are NOT paragraph breaks\n",
    "    text = re.sub(r'(?<!\\n)\\n(?![\\n•\\-\\d])', ' ', text)\n",
    "\n",
    "    # Collapse triple+ blank lines to double\n",
    "    text = re.sub(r'\\n{3,}', '\\n\\n', text)\n",
    "\n",
    "    # Normalise section numbering header style: \"8.3 TITLE\" → \"## 8.3 TITLE\"\n",
    "    text = re.sub(r'^(\\d+\\.\\d+(?:\\.\\d+)?)\\s+([A-Z][A-Z\\s]{3,})',\n",
    "                  r'## \\1 \\2', text, flags=re.MULTILINE)\n",
    "\n",
    "    # Remove stray page number lines (e.g. just \"205\" on a line)\n",
    "    text = re.sub(r'^\\s*\\d{3}\\s*$', '', text, flags=re.MULTILINE)\n",
    "\n",
    "    return text.strip()\n",
    "\n",
    "\n",
    "def normalize_all_pages(ocr_results: List[Dict]) -> List[Dict]:\n",
    "    \"\"\"Normalize all pages and attach metadata.\"\"\"\n",
    "    normalized = []\n",
    "    for r in ocr_results:\n",
    "        nr = dict(r)  # shallow copy\n",
    "        nr[\"text\"] = normalize_page(r.get(\"text\", \"\"))\n",
    "        nr[\"chars\"] = len(nr[\"text\"])\n",
    "        normalized.append(nr)\n",
    "\n",
    "    total = sum(p[\"chars\"] for p in normalized)\n",
    "    good  = sum(1 for p in normalized if p[\"chars\"] > 100)\n",
    "    print(f\"✅ Normalized {len(normalized)} pages\")\n",
    "    print(f\"   Good pages  : {good}/{len(normalized)}\")\n",
    "    print(f\"   Total chars : {total:,}\")\n",
    "\n",
    "    with open(os.path.join(OUTPUT_DIR, \"normalized_pages.json\"), \"w\") as f:\n",
    "        json.dump(normalized, f, ensure_ascii=False, indent=2)\n",
    "\n",
    "    return normalized\n",
