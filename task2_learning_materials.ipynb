    "# ─── Build the Full Structured JSON Document ──────────────────────────────────\n",
    "STRUCT_CACHE = os.path.join(CACHE_DIR, \"structured_document.json\")\n",
    "CHUNK_SIZE   = 3   # pages per LLM call (balance context vs cost)\n",
    "\n",
    "def build_structured_document(normalized: List[Dict],\n",
    "                               force_rerun: bool = False) -> Dict:\n",
    "    \"\"\"Chunk pages, structure each chunk, merge into final document JSON.\"\"\"\n",
    "    if not force_rerun and os.path.exists(STRUCT_CACHE):\n",
    "        with open(STRUCT_CACHE) as f:\n",
    "            doc = json.load(f)\n",
    "        print(f\"⚡ Loaded structured document from cache ({len(doc['sections'])} sections)\")\n",
    "        return doc\n",
    "\n",
    "    all_sections: List[Dict] = []\n",
    "    chunks = [normalized[i:i+CHUNK_SIZE]\n",
    "              for i in range(0, len(normalized), CHUNK_SIZE)]\n",
    "\n",
    "    print(f\"🏗️  Structuring {len(normalized)} pages in {len(chunks)} chunks...\")\n",
    "    for chunk in tqdm(chunks, desc=\"Structuring\", unit=\"chunk\"):\n",
    "        text = \"\\n\\n\".join(p[\"text\"] for p in chunk if p.get(\"text\"))\n",
    "        if not text.strip():\n",
    "            continue\n",
    "        pages = [p[\"page\"] for p in chunk]\n",
    "        print(f\"\\n  Pages {pages}\")\n",
    "        sections = structure_chunk(text, pages)\n",
    "        # Ensure page metadata is always present\n",
    "        for s in sections:\n",
    "            s.setdefault(\"page_start\", pages[0])\n",
    "            s.setdefault(\"page_end\", pages[-1])\n",
    "            s.setdefault(\"key_concepts\", [])\n",
    "        all_sections.extend(sections)\n",
    "        time.sleep(2)  # rate-limit between chunks\n",
    "\n",
    "    doc = {\n",
    "        \"title\": \"Chapter 8: Electromagnetic Waves\",\n",
    "        \"subject\": \"Physics\",\n",
    "        \"source\": \"NCERT Physics Textbook (Class 12)\",\n",
    "        \"total_pages\": len(normalized),\n",
    "        \"total_sections\": len(all_sections),\n",
    "        \"sections\": all_sections\n",
    "    }\n",
    "\n",
    "    with open(STRUCT_CACHE, \"w\") as f:\n",
    "        json.dump(doc, f, ensure_ascii=False, indent=2)\n",
    "    with open(os.path.join(OUTPUT_DIR, \"structured_document.json\"), \"w\") as f:\n",
    "        json.dump(doc, f, ensure_ascii=False, indent=2)\n",
    "\n",
    "    print(f\"\\n✅ Structured document: {len(all_sections)} sections\")\n",
    "    return doc\n",
    "\n",
    "\n",
    "STRUCTURED_DOC = build_structured_document(NORMALIZED)\n",
    "\n",
    "# Pretty-print section index\n",
    "print(\"\\n📑 Section Index:\")\n",
    "for i, s in enumerate(STRUCTURED_DOC[\"sections\"], 1):\n",
    "    print(f\"  {i:2}. [{s.get('section_type','?'):10}] p{s.get('page_start','?')}-{s.get('page_end','?')}  {s.get('title','Untitled')[:60]}\")"
   ]
