    "# ─── Optional: Upload PDF ─────────────────────────────────────────────────────\n",
    "def upload_pdf_if_needed(target_path: str) -> str:\n",
    "    \"\"\"Upload PDF via Colab file picker if not already present.\"\"\"\n",
    "    if os.path.exists(target_path):\n",
    "        size_mb = os.path.getsize(target_path) / 1_048_576\n",
    "        print(f\"✅ PDF found: {target_path}  ({size_mb:.1f} MB)\")\n",
    "        return target_path\n",
    "\n",
    "    print(\"📤 PDF not found — launching uploader...\")\n",
    "    try:\n",
    "        from google.colab import files\n",
    "        uploaded = files.upload()\n",
    "        fname = list(uploaded.keys())[0]\n",
    "        dest = os.path.join(\"/content\", fname)\n",
    "        with open(dest, \"wb\") as f:\n",
    "            f.write(uploaded[fname])\n",
    "        print(f\"✅ Uploaded → {dest}\")\n",
    "        return dest\n",
    "    except Exception as e:\n",
    "        raise FileNotFoundError(\n",
    "            f\"PDF not found at '{target_path}' and upload failed: {e}\\n\"\n",
    "            \"Please upload the PDF manually to /content/ and update PDF_PATH.\"\n",
    "        )\n",
    "\n",
    "\n",
    "def pdf_to_images(pdf_path: str, dpi: int = 200) -> List[Image.Image]:\n",
    "    \"\"\"Convert PDF pages to PIL Images at given DPI.\"\"\"\n",
    "    print(f\"🔄 Converting PDF → images (DPI={dpi}) ...\")\n",
    "    images = convert_from_path(pdf_path, dpi=dpi, fmt=\"PNG\", thread_count=4)\n",
    "    print(f\"✅ {len(images)} pages converted\")\n",
    "    return images\n",
    "\n",
    "\n",
    "def image_to_base64(img: Image.Image) -> str:\n",
    "    \"\"\"Return base64-encoded PNG string for an image.\"\"\"\n",
    "    buf = io.BytesIO()\n",
    "    img.save(buf, format=\"PNG\")\n",
    "    return base64.b64encode(buf.getvalue()).decode()\n",
    "\n",
    "\n",
    "def enhance_for_ocr(img: Image.Image) -> Image.Image:\n",
    "    \"\"\"Apply light sharpening + contrast boost to aid OCR accuracy.\"\"\"\n",
    "    img = img.convert(\"RGB\")\n",
    "    img = ImageEnhance.Contrast(img).enhance(1.3)\n",
    "    img = ImageEnhance.Sharpness(img).enhance(1.5)\n",
    "    return img\n",
    "\n",
    "\n",
    "PDF_PATH = upload_pdf_if_needed(PDF_PATH)\n",
    "PDF_IMAGES = pdf_to_images(PDF_PATH)"
   ]
